# --- Database ---
# Leave empty in development to use the embedded PGlite database (./.pglite).
# In production set the PostgreSQL connection string (e.g. from Railway).
DATABASE_URL=

# --- Auth ---
# Required. Generate with: openssl rand -base64 32  (any long random string)
BETTER_AUTH_SECRET=
# Public URL of the app (production), e.g. https://crm.rodeodrive.com.qa
BETTER_AUTH_URL=http://localhost:3000
# Optional: extra origins allowed to sign in (comma-separated), e.g. the
# Railway-generated domain while the custom domain's DNS propagates
TRUSTED_ORIGINS=

# --- Email (scheduled reports) ---
# Leave empty to record sends as SIMULATED. Set both for real emails via Resend.
RESEND_API_KEY=
EMAIL_FROM="Rodeo Drive CRM <crm@example.com>"

# --- File storage (drive) ---
# Local directory for uploaded files (default ./storage). Use a persistent
# volume in production, or swap the driver in src/lib/storage.ts to R2/MinIO.
STORAGE_DIR=

# --- Organization theme (see public/themes/) ---
NEXT_PUBLIC_ORG_THEME=default

# --- Root admin (created by `npm run db:seed` if it does not exist) ---
ROOT_ADMIN_EMAIL=admin@rodeodrive.work
ROOT_ADMIN_PASSWORD=change-me-now
ROOT_ADMIN_NAME=Administrator
