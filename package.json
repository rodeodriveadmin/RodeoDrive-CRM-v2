{
  "name": "rodeodrive-crm",
  "version": "2.0.0",
  "private": true,
  "description": "Rodeo Drive CRM v2 — workshop CRM rebuilt on a portable, AWS-free stack",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed:dev": "tsx --env-file=.env.local src/db/seed.ts",
    "deploy:setup": "drizzle-kit push && tsx src/db/seed.ts"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.3.0",
    "better-auth": "^1.3.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.14.0",
    "next": "^15.5.4",
    "pg": "^8.16.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "server-only": "^0.0.1",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
